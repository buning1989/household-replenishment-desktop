{
  "name": "household-replenishment-desktop",
  "version": "0.1.3",
  "private": true,
  "author": "403家庭管家",
  "description": "A quiet household replenishment reminder for macOS and Windows.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "start": "electron .",
    "package:mac": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg"
  },
  "dependencies": {
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "cn.home.replenishment",
    "productName": "403家庭管家",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg"
      ]
    }
  }
}

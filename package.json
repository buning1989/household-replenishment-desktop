{
  "name": "household-replenishment-desktop",
  "version": "0.1.3",
  "private": true,
  "author": "403家庭管家",
  "description": "A quiet household replenishment reminder for macOS and Windows.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite --host 127.0.0.1 --strictPort",
    "dev:landing": "vite --host 127.0.0.1 --strictPort --open /landing/",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:landing": "vite build --config vite.landing.config.ts",
    "start": "electron .",
    "package:mac": "npm run test && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "package:win": "npm run test && npm run build && electron-builder --win --x64",
    "test": "node --test tests/*.mjs",
    "package:win:arm64": "npm run test && npm run build && electron-builder --win --arm64"
  },
  "dependencies": {
    "motion": "^12.40.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "build": {
    "appId": "cn.home.replenishment",
    "productName": "403家庭管家",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icons/**/*",
      "THIRD_PARTY_NOTICES.md",
      "package.json"
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.lifestyle",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icons/icon_1024.png",
      "executableName": "HouseholdManager403"
    },
    "nsis": {
      "shortcutName": "403家庭管家"
    },
    "linux": {
      "icon": "build/icons/icon.png"
    }
  },
  "allowScripts": {
    "electron@39.8.10": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.27.7": true,
    "fsevents@2.3.3": true
  }
}
